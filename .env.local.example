# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/portal/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal

# Admin identity — must match the Clerk account email for the admin user
ADMIN_EMAIL=you@heuristicalabs.com

# Token signing secret — generate: openssl rand -base64 32
TOKEN_SECRET=...

# Upstash Redis (token store + request rate limiting)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Resend (transactional email)
RESEND_API_KEY=re_...
FROM_EMAIL=portal@heuristicalabs.com

# VPS content origin — Nginx server gated behind X-Portal-Secret header
VPS_ORIGIN=https://files.heuristicalabs.com
VPS_SECRET=...   # generate: openssl rand -base64 32

# App base URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://portal.heuristicalabs.com
